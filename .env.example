# Persistent state
TME_DB=/data/tme.db
TME_HOST=0.0.0.0
HRS_ALLOCATION_GAP_PCT=3
PROCESSOR_INTERVAL_SECONDS=0.05
TME_QUEUE_TOKEN=replace-with-a-long-random-secret

# QuickNode HyperCore collector (collector stays disabled if endpoint/token are absent)
HC_GRPC_ENDPOINT=your-endpoint:443
HC_GRPC_TOKEN=your-token
HC_GRPC_SERVER_NAME=your-endpoint-host
QUICKNODE_INFO_URL=https://your-endpoint-host/your-token/info
TME_PERP_DEXES=
TME_WALLET_REFRESH_SECONDS=1